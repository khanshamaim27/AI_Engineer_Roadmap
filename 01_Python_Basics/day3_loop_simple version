#find largest number 
numbers = [45, 23, 89, 12, 67, 34]
largest = numbers[0]  # Start with first number
for num in numbers:
    if num>largest:
        largest=num
print(f"Numbers:{numbers}")
print(f"Largest: {largest}")

numbers = [45, 23, 89, 12, 67, 34]
smallest = numbers[0]  # Start with first number

for num in numbers:
    if num < smallest:
        smallest = num

print(f"Numbers: {numbers}")
print(f"Smallest: {smallest}")

